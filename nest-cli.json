{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false,
    "assets": [
      { "include": "assets/**/*", "outDir": "dist", "watchAssets": true }
    ]
  }
}
