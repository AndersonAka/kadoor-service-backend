generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MANAGER
  MERCHANT
}

enum PartnerType {
  PHYSICAL
  COMPANY
  FREELANCE
}

enum PartnerCategory {
  AUTO
  APARTMENT
  BOTH
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum GiftCardStatus {
  PENDING
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  DISPUTED
  OVERDUE
}

enum InvoiceLineCategory {
  DAMAGE
  LATE_RETURN
  MILEAGE_OVERAGE
  TRAFFIC_FINE
  CLEANING
  OTHER
}

/// Sens du solde affiché sur la facture (paiement client vs remboursement Kadoor)
enum InvoiceSettlementType {
  CLIENT_PAYS
  KADOR_REFUND
  ZERO_BALANCE
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String?   // Optionnel pour les utilisateurs OAuth
  firstName           String?
  lastName            String?
  phone               String?
  address             String?   // Lieu d'habitation de l'utilisateur
  role                Role      @default(USER)
  googleId            String?   @unique // ID Google pour OAuth
  avatar              String?   // URL de l'avatar (Google profile picture)
  provider            String?   @default("local") // "local" ou "google"
  isActive            Boolean   @default(true) // Pour la désactivation de compte (soft delete)
  resetPasswordToken  String?   // Token pour réinitialisation du mot de passe
  resetPasswordExpires DateTime? // Expiration du token
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  bookings        Booking[]
  reviews         Review[]
  incidents       Incident[]
  favorites       Favorite[]
  notifications   Notification[]
  invoices        Invoice[]    @relation("CustomerInvoices")
  createdInvoices Invoice[]    @relation("AdminCreatedInvoices")
  partner         Partner?
  giftCards       GiftCard[]
}

/// Tarification partagée par type de véhicule (location + forfaits km journaliers + assurance)
model VehicleTypePricing {
  id                       String   @id @default(uuid())
  vehicleType              String   @unique // Berline, SUV, Utilitaire, Fourgonnette, Luxe
  /// Forfait « moins de 100 km/jour » — montant journalier (FCFA)
  tier1MileageDailyAmount  Float    @default(30000)
  /// Forfait « 100 à 200 km/jour » — montant journalier (FCFA)
  tier2MileageDailyAmount  Float    @default(45000)
  /// Forfait « 201 à 250 km/jour » — montant journalier (FCFA)
  tier3MileageDailyAmount  Float    @default(70000)
  overagePricePerKm        Float    @default(350)
  insuranceAmount          Float    @default(15000)
  insuranceDiscountPercent Float   @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Vehicle {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String   // Berline, SUV, Luxe, etc.
  make        String?
  model       String?
  year        Int?
  fuel        String?
  transmission String?
  seats       Int?
  location    String?
  isAvailable Boolean  @default(true)
  images      String[]
  features    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
  reviews     Review[]
  incidents   Incident[]
  favorites   Favorite[]
}

model Apartment {
  id            String   @id @default(uuid())
  title         String
  description   String
  type          String?  // Studio, T1, T2, T3, T4, Villa, etc.
  address       String
  city          String
  pricePerNight Float
  cleaningFee   Float    @default(0) // Frais de nettoyage (forfait unique par séjour)
  bedrooms      Int
  bathrooms     Int
  area          Float
  images        String[]
  features      String[]
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings    Booking[]
  reviews     Review[]
  incidents   Incident[]
  favorites   Favorite[]
}

model Favorite {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId   String?
  vehicle     Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@unique([userId, vehicleId])
  @@unique([userId, apartmentId])
}

model Booking {
  id                String   @id @default(uuid())
  startDate         DateTime
  endDate           DateTime
  pickupTime        String?  // Heure de prise en charge (HH:MM)
  returnTime        String?  // Heure de restitution (HH:MM)
  totalPrice        Float
  status            String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  paystackReference String?  // UUID reference used for Paystack payment tracking

  // Option assurance supplémentaire (véhicule uniquement)
  hasInsurance      Boolean  @default(false)
  insurancePrice    Float?   // Montant fixe de l'assurance ajouté au total
  insuranceDiscount Float?   // Montant de réduction appliqué sur le prix de base

  // Frais de nettoyage (appartement uniquement, forfait unique par séjour)
  cleaningFee       Float?

  // Forfait kilométrique (véhicule uniquement)
  mileagePackage    String? // TIER1 (<100 km/j) | TIER2 (100-200 km/j) | TIER3 (201-250 km/j)
  mileagePackageCost Float? // Coût total du forfait sur la durée du séjour

  // Code promo / rabais
  promoCode         String?  // Code utilisé (snapshot à la réservation)
  promoCodeId       String?
  promoCodeRel      PromoCode? @relation(fields: [promoCodeId], references: [id])
  promoDiscount     Float?   // Montant de réduction appliqué

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id])
  invoices    Invoice[]

  /// Caution / dépôt de garantie (optionnel)
  depositAmount        Float?
  depositPaymentMethod String?
  depositCollectedAt   DateTime?
  depositNote          String?
}

model Invoice {
  id                String      @id @default(uuid())
  reference         String      @unique
  status            InvoiceStatus @default(DRAFT)
  issuedAt          DateTime    @default(now())
  dueAt             DateTime?
  subtotal          Float
  taxAmount         Float       @default(0)
  totalAmount       Float
  currency          String      @default("FCFA")
  paystackReference String?
  sentAt            DateTime?
  paidAt            DateTime?
  internalNote      String?
  customerNote      String?
  /// Snapshot caution au moment de la facture (null = pas de caution)
  depositAmount           Float?
  depositDeductionsAmount Float?
  depositRefundAmount     Float?
  depositSupplementAmount Float?
  depositPaymentMethod    String?
  depositNote             String?
  settlementType          InvoiceSettlementType @default(CLIENT_PAYS)
  /// Montant principal : à payer (client) ou à rendre (Kadoor selon settlementType)
  amountDue               Float                 @default(0)
  refundedAt              DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  bookingId         String
  booking           Booking     @relation(fields: [bookingId], references: [id])
  userId            String
  user              User        @relation("CustomerInvoices", fields: [userId], references: [id])
  createdById       String
  createdBy         User        @relation("AdminCreatedInvoices", fields: [createdById], references: [id])

  lines             InvoiceLine[]
}

model InvoiceLine {
  id          String              @id @default(uuid())
  category    InvoiceLineCategory
  description String
  quantity    Float               @default(1)
  unitPrice   Float
  lineTotal   Float
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  invoiceId   String
  invoice     Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id])
}

model HeroSlide {
  id           Int      @id @default(autoincrement())
  titleFr      String
  titleEn      String
  subtitleFr   String
  subtitleEn   String
  imageUrl     String
  buttonTextFr String?
  buttonTextEn String?
  buttonLink   String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  designation String   // Ex: "Entrepreneur - Douala", "Tourist - USA"
  comment     String   // Le témoignage/commentaire
  imageUrl    String?  // URL de l'image du client (optionnel)
  isActive    Boolean  @default(true)
  order       Int      @default(0) // Pour ordonner l'affichage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum IncidentType {
  ACCIDENT
  PANNE
  SINISTRE
  VOL
  DOMMAGE
  AUTRES
}

enum IncidentStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Incident {
  id          String        @id @default(uuid())
  type        IncidentType
  title       String
  description String
  location    String?
  date        DateTime?
  firstName   String
  lastName    String
  email       String
  phone       String?
  status      IncidentStatus @default(PENDING)
  userId      String?        // Optionnel : si l'utilisateur est connecté
  user        User?          @relation(fields: [userId], references: [id])
  vehicleId   String?        // Optionnel : si l'incident concerne un véhicule
  vehicle     Vehicle?       @relation(fields: [vehicleId], references: [id])
  apartmentId String?        // Optionnel : si l'incident concerne un appartement
  apartment   Apartment?     @relation(fields: [apartmentId], references: [id])
  images      String[]       // Photos de l'incident
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PromoCode {
  id             String   @id @default(uuid())
  code           String   @unique           // Le code à saisir (insensible à la casse côté API)
  description    String?
  discountType   String   @default("PERCENT") // PERCENT | FIXED
  discountValue  Float                         // Valeur (% si PERCENT, FCFA si FIXED)
  minAmount      Float?                        // Montant minimum de la réservation (optionnel)
  maxUses        Int?                          // Nombre maximum d'utilisations (null = illimité)
  usedCount      Int      @default(0)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean  @default(true)
  appliesTo      String   @default("ALL")      // ALL | VEHICLE | APARTMENT
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings       Booking[]
}

model ContactMessage {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  status    String   @default("NEW") // NEW, READ, REPLIED, ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(uuid())
  key             String   @unique // Clé unique du paramètre (ex: "newBadgeDays")
  value           String   // Valeur du paramètre
  description     String?  // Description du paramètre
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum NotificationType {
  RESERVATION_NEW
  RESERVATION_CONFIRMED
  RESERVATION_CANCELLED
  RESERVATION_COMPLETED
  PAYMENT_RECEIVED
  REVIEW_NEW
  INCIDENT_NEW
  INCIDENT_UPDATED
  SYSTEM
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  titleFr     String
  titleEn     String
  messageFr   String
  messageEn   String
  link        String?          // Lien vers la ressource concernée
  isRead      Boolean          @default(false)
  isGlobal    Boolean          @default(false) // Pour les notifications admin globales
  userId      String?          // Null si notification globale admin
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// ─── Partenaires marchands (KYC) ──────────────────────────────────────────────

model Partner {
  id          String          @id @default(uuid())
  partnerType PartnerType
  category    PartnerCategory
  status      PartnerStatus   @default(PENDING)

  // §1A — Personne physique
  fullName     String?
  birthDate    DateTime?
  birthPlace   String?
  idNumber     String?
  idType       String?   // passeport / permis / carte d'identité
  idExpiry     DateTime?
  nationality  String?

  // §1B — Personne morale
  legalName            String?
  registrationNumber   String?
  registrationDate     DateTime?
  legalForm            String?
  incorporationCountry String?
  businessSector       String?

  // §1C — Coordonnées
  address  String?
  phone    String?
  phone2   String?
  email    String
  website  String?

  // §2 — Bénéficiaires effectifs (JSON : [{name, title, nationality, ownershipPct, birthDate, idNumber}])
  beneficiaries Json?
  isPPE         Boolean @default(false)
  ppeDetails    String?

  // §3 — Informations financières
  fundSources            String[]
  fundSourceOther        String?
  estimatedAnnualRevenue Float?
  estimatedMonthlyTx     Int?
  avgTransactionValue    Float?
  maxTransactionValue    Float?
  bank1Name              String?
  bank1Country           String?
  bank2Name              String?
  bank2Country           String?
  otherPlatforms         String[]

  // §4 — Section automobile
  vehicleCount     Int?
  vehicleTypes     String[]
  fleetTotalValue  Float?
  fleetRenewalYear Int?
  autoCompliance   String[]
  geoZones         String?
  pickupPoints     String?

  // §5 — Section appartement
  unitCount            Int?
  housingTypes         String[]
  mainCities           String?
  avgMonthlyRent       Float?
  realEstateCompliance String[]
  includedServices     String[]

  // §7 — Évaluation des risques (interne)
  riskScoreCountry      Float?
  riskScoreShareholders Float?
  riskScorePPE          Float?
  riskScoreFunds        Float?
  riskScoreVolume       Float?
  riskScoreReputation   Float?
  riskScoreCompliance   Float?
  riskTotalScore        Float?
  riskLevel             RiskLevel?
  riskNotes             String?
  riskMeasures          String?
  nextReviewAt          DateTime?

  // §8 — Signatures
  signedAt      DateTime?
  signedBy      String?
  kycAnalyst    String?
  validatedAt   DateTime?
  validatedById String?

  // Compte utilisateur MERCHANT lié
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  documents            PartnerDocument[]
  giftCardTransactions GiftCardTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartnerDocument {
  id         String   @id @default(uuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  docType    String   // ID_CARD | KBIS | PROOF_OF_ADDRESS | INSURANCE | VEHICLE_REGISTRATION | INSPECTION | LEASE | MUNICIPAL_PERMIT | PHOTOS | CONTRACT | AML_FORM
  fileUrl    String
  isVerified Boolean  @default(false)
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Cartes cadeaux ───────────────────────────────────────────────────────────

model GiftCard {
  id     String        @id @default(uuid())
  code   String        @unique
  status GiftCardStatus @default(PENDING)

  initialAmount  Float
  currentBalance Float

  // Personnalisation
  theme          String?
  recipientName  String?
  recipientEmail String?
  recipientPhone String?   // Format +225XXXXXXXXXX (numérotation ivoirienne)
  senderMessage  String?

  // Validité
  validFrom  DateTime  @default(now())
  validUntil DateTime

  // Paiement
  paystackReference String?

  // Acheteur
  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions GiftCardTransaction[]
  otps         GiftCardOtp[]

  // Cycle de vie admin
  validatedAt   DateTime?
  validatedById String?
  cancelledAt   DateTime?
  cancelReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GiftCardOtp {
  id         String    @id @default(uuid())
  giftCardId String
  giftCard   GiftCard  @relation(fields: [giftCardId], references: [id])

  codeHash      String    // OTP haché (bcrypt) — jamais stocké en clair
  expiresAt     DateTime  // now + 10 minutes
  usedAt        DateTime? // null = non utilisé / invalidé
  attempts      Int       @default(0) // tentatives incorrectes (max 3)
  cooldownUntil DateTime? // blocage anti-spam (2 min entre demandes)

  createdAt DateTime @default(now())
}

model GiftCardTransaction {
  id String @id @default(uuid())

  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id])

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id])

  amountDeducted Float
  balanceBefore  Float
  balanceAfter   Float

  note       String?
  receiptRef String?

  createdAt DateTime @default(now())
}
